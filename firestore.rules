rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/userProfiles/000000).data.uid == request.auth.uid;
    }

    match /userProfiles/{matricula} {
      // Permite verificar se a matrícula existe antes do login
      allow get: if true;
      allow list: if isSignedIn();
      
      // Permite criação inicial
      allow create: if true;
      
      // Permite reset de senha (limpar UID e aumentar versão) ou atualização pelo dono/admin
      allow update: if (
        // Caso 1: Reset de senha (bloqueado para admin 000000 publicamente)
        (matricula != '000000' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['authVersion', 'uid', 'updatedAt'])) ||
        // Caso 2: Atualização normal (logado)
        (isSignedIn() && (
          !('uid' in resource.data) || 
          resource.data.uid == request.auth.uid || 
          isAdmin()
        ))
      );
      
      allow delete: if isAdmin();

      match /monthlySummaries/{summaryId} {
        allow read, write: if isSignedIn() && (
          get(/databases/$(database)/documents/userProfiles/$(matricula)).data.uid == request.auth.uid ||
          isAdmin()
        );
        
        match /dailyEntries/{entryId} {
          allow read, write: if isSignedIn() && (
            get(/databases/$(database)/documents/userProfiles/$(matricula)).data.uid == request.auth.uid ||
            isAdmin()
          );
        }
      }
    }
  }
}