rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/userProfiles/000000).data.uid == request.auth.uid;
    }

    match /userProfiles/{matricula} {
      // Permite verificar se a matrícula existe antes do login
      allow get: if true;
      allow list: if isSignedIn();
      
      // Permite criação inicial (auto-registro)
      allow create: if true;
      
      // Permite atualização pelo dono ou admin
      allow update: if (
        isSignedIn() && (
          // O próprio usuário pode atualizar (vincular UID inicial ou dados próprios)
          (!('uid' in resource.data) || resource.data.uid == request.auth.uid) ||
          // Admin pode atualizar qualquer campo (inclusive resetar)
          isAdmin()
        )
      );
      
      allow delete: if isAdmin();

      match /monthlySummaries/{summaryId} {
        allow read, write: if isSignedIn() && (
          get(/databases/$(database)/documents/userProfiles/$(matricula)).data.uid == request.auth.uid ||
          isAdmin()
        );
        
        match /dailyEntries/{entryId} {
          allow read, write: if isSignedIn() && (
            get(/databases/$(database)/documents/userProfiles/$(matricula)).data.uid == request.auth.uid ||
            isAdmin()
          );
        }
      }
    }
  }
}
