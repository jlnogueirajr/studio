rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PONTO ÁGIL - FIRESTORE SECURITY RULES
     * Ajustado para permitir a verificação de existência de perfil antes do login.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.isAdmin == true;
    }

    match /userProfiles/{userId} {
      // Permite 'get' público para que a tela de login verifique se a matrícula existe.
      // 'list' continua restrito a administradores.
      allow get: if true;
      allow list: if isAdmin();
      
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();

      match /monthlySummaries/{summaryId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId) || isAdmin();
        allow delete: if isAdmin();

        match /dailyEntries/{entryId} {
          allow get, list: if isOwner(userId) || isAdmin();
          allow create, update: if isOwner(userId) || isAdmin();
          allow delete: if isAdmin();
        }
      }
    }
  }
}