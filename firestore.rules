rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Verifica se o usuário é o mestre 000000 ou se tem a flag isAdmin no documento
      return isSignedIn() && (
        exists(/databases/$(database)/documents/userProfiles/000000) && 
        get(/databases/$(database)/documents/userProfiles/000000).data.uid == request.auth.uid
      );
    }

    match /userProfiles/{matricula} {
      allow get: if true;
      allow list: if isSignedIn();
      
      // Permite criação inicial
      allow create: if true;
      
      // Permite atualização pelo dono ou admin
      allow update: if (
        isSignedIn() && (
          (request.auth.uid == resource.data.uid) ||
          isAdmin()
        )
      );
      
      // Apenas admin pode deletar
      allow delete: if isAdmin();

      match /monthlySummaries/{summaryId} {
        allow read, write: if isSignedIn() && (
          get(/databases/$(database)/documents/userProfiles/$(matricula)).data.uid == request.auth.uid ||
          isAdmin()
        );
        
        match /dailyEntries/{entryId} {
          allow read, write: if isSignedIn() && (
            get(/databases/$(database)/documents/userProfiles/$(matricula)).data.uid == request.auth.uid ||
            isAdmin()
          );
        }
      }
    }
  }
}