rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    match /userProfiles/{matricula} {
      // Permite verificar se a matrícula existe antes do login
      allow get: if true;
      allow list: if isSignedIn();
      
      // Permite criação inicial
      allow create: if true;
      
      // Permite atualizar se for o dono vinculando o UID ou se for o admin 000000
      allow update: if isSignedIn() && (
        !('uid' in resource.data) || 
        resource.data.uid == request.auth.uid || 
        get(/databases/$(database)/documents/userProfiles/000000).data.uid == request.auth.uid
      );
      
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/userProfiles/000000).data.uid == request.auth.uid;

      match /monthlySummaries/{summaryId} {
        allow read, write: if isSignedIn() && (
          get(/databases/$(database)/documents/userProfiles/$(matricula)).data.uid == request.auth.uid ||
          get(/databases/$(database)/documents/userProfiles/000000).data.uid == request.auth.uid
        );
        
        match /dailyEntries/{entryId} {
          allow read, write: if isSignedIn() && (
            get(/databases/$(database)/documents/userProfiles/$(matricula)).data.uid == request.auth.uid ||
            get(/databases/$(database)/documents/userProfiles/000000).data.uid == request.auth.uid
          );
        }
      }
    }
  }
}