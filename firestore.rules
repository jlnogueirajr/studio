
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // Função de Admin: verifica se o UID logado é o vinculado à matrícula mestre 000000
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/userProfiles/000000) && 
        get(/databases/$(database)/documents/userProfiles/000000).data.uid == request.auth.uid
      );
    }

    match /userProfiles/{matricula} {
      // Permite que qualquer um veja a matrícula para saber se precisa de senha ou não
      allow get: if true;
      
      // Admin pode listar todos, usuários comuns podem ver o próprio
      allow list: if isSignedIn();
      
      // Permite criação inicial (auto-cadastro)
      allow create: if true;
      
      // Permite atualização pelo dono, admin, ou se o perfil estiver sem UID (foi resetado)
      allow update: if isSignedIn() && (
        isAdmin() || 
        (resource.data.uid == request.auth.uid) ||
        (!('uid' in resource.data)) // Permite que o usuário vincule seu novo UID após um reset
      );
      
      // Apenas admin pode deletar
      allow delete: if isAdmin();

      // Subcoleções de histórico de ponto
      match /monthlySummaries/{summaryId} {
        allow read, write: if isSignedIn() && (
          isAdmin() ||
          (get(/databases/$(database)/documents/userProfiles/$(matricula)).data.uid == request.auth.uid)
        );
        
        match /dailyEntries/{entryId} {
          allow read, write: if isSignedIn() && (
            isAdmin() ||
            (get(/databases/$(database)/documents/userProfiles/$(matricula)).data.uid == request.auth.uid)
          );
        }
      }
    }
  }
}
