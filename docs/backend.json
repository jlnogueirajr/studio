
{
  "entities": {
    "Employee": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Employee",
      "type": "object",
      "description": "Represents an employee whose time records are tracked in the Ponto Ágil application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Employee entity."
        },
        "registrationNumber": {
          "type": "string",
          "description": "The employee's unique registration number."
        },
        "expectedMonthlyHours": {
          "type": "number",
          "description": "Standard monthly hours."
        },
        "fixedDsrDays": {
          "type": "array",
          "description": "Array of day indices (0-6, where 0 is Sunday) that are fixed DSR/Folga days.",
          "items": {
            "type": "number"
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "registrationNumber",
        "expectedMonthlyHours",
        "createdAt",
        "updatedAt"
      ]
    },
    "MonthlyTimeLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "MonthlyTimeLog",
      "type": "object",
      "description": "Stores the consolidated monthly time tracking data.",
      "properties": {
        "id": {
          "type": "string"
        },
        "employeeId": {
          "type": "string"
        },
        "year": {
          "type": "number"
        },
        "month": {
          "type": "number"
        },
        "fetchedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "employeeId",
        "year",
        "month",
        "fetchedAt"
      ]
    },
    "DailyEntry": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "DailyEntry",
      "type": "object",
      "description": "Represents a single day's time tracking record.",
      "properties": {
        "id": {
          "type": "string"
        },
        "monthlyTimeLogId": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "times": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dailyTotalHours": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "monthlyTimeLogId",
        "date",
        "times",
        "dailyTotalHours"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}/employees/{employeeId}",
        "definition": {
          "entityName": "Employee",
          "schema": {
            "$ref": "#/backend/entities/Employee"
          },
          "description": "Stores employee records."
        }
      },
      {
        "path": "/users/{userId}/employees/{employeeId}/monthlyTimeLogs/{monthlyTimeLogId}",
        "definition": {
          "entityName": "MonthlyTimeLog",
          "schema": {
            "$ref": "#/backend/entities/MonthlyTimeLog"
          },
          "description": "Contains monthly time logs."
        }
      },
      {
        "path": "/users/{userId}/employees/{employeeId}/monthlyTimeLogs/{monthlyTimeLogId}/dailyEntries/{dailyEntryId}",
        "definition": {
          "entityName": "DailyEntry",
          "schema": {
            "$ref": "#/backend/entities/DailyEntry"
          },
          "description": "Stores daily time entries."
        }
      }
    ]
  }
}
